{
    "compilerOptions": {
        "rootDir": "ts",
        "outDir": "js",
        "target": "ES2022",
        "module": "commonjs",       /* supports modules */
        "esModuleInterop": true,    /* former exports retrocompatibility */
        "types": ["node"],
        "noEmitOnError": true,
        "strict": true,
        "noImplicitAny": true,
        "noImplicitThis": false,
        "sourceMap": true,          /* for ts debug */
        "pretty": true
    },
    "exclude": ["node_modules"],
    "include": [
        "ts/*"
    ]
}

/* npm run dev */
